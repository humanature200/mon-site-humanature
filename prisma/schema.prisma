// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 1. Les Utilisateurs
model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String     
  role      String     @default("USER") // USER ou ADMIN
  createdAt DateTime   @default(now())
  comments  Comment[]
}

// 2. Les Tutoriels (Identifiant calé en String/UUID pour correspondre à ton projet)
model Tutorial {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique // ex: "apprendre-node-js"
  description String    @db.Text
  videoUrl    String    
  createdAt   DateTime  @default(now())
  comments    Comment[]
}

// 3. Les Commentaires (Version Forum Globale + Option Tuto corrigée)
model Comment {
  id         String   @id @default(uuid())
  content    String   @db.Text             
  createdAt  DateTime @default(now())
  
  // Auteur du message (Liaison Forum)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  userName   String   

  // Liaison Optionnelle avec les Tutoriels (Type String? corrigé !)
  tutorialId String?
  tutorial   Tutorial? @relation(fields: [tutorialId], references: [id], onDelete: Cascade)
}

// 4. Suivi de progression (Type tutorialId corrigé en String !)
model Progress {
  id         Int      @id @default(autoincrement())
  userId     String
  tutorialId String
  createdAt  DateTime @default(now())

  @@unique([userId, tutorialId])
}